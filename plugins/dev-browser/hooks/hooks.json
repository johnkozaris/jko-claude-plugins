{
  "description": "dev-browser plugin hooks: detect installation at session start, cleanup on end",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/ensure-dev-browser.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "command -v dev-browser &>/dev/null && dev-browser stop 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
